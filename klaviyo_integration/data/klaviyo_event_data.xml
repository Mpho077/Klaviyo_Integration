<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job to retry failed Klaviyo events -->
    <record id="ir_cron_retry_klaviyo_events" model="ir.cron">
        <field name="name">Klaviyo: Retry Failed Events</field>
        <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="state">code</field>
        <field name="code">model._cron_retry_failed_klaviyo_events()</field>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
