<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_klaviyo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.klaviyo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Klaviyo" string="Klaviyo" name="klaviyo_integration" groups="base.group_system">
                    <block title="Klaviyo Integration Settings">
                        <setting string="Enable Klaviyo Integration" help="Enable or disable sending events to Klaviyo">
                            <field name="klaviyo_enabled"/>
                        </setting>
                        <setting string="API Key" help="Enter your Klaviyo Private API Key">
                            <field name="klaviyo_api_key" password="True"/>
                        </setting>
                        <setting string="API Revision" help="Klaviyo API revision date">
                            <field name="klaviyo_api_revision"/>
                        </setting>
                    </block>
                    <block title="Supported Events">
                        <div class="text-muted">
                            <p>The following events are sent to Klaviyo when tickets are resolved:</p>
                            <ul>
                                <li><strong>complaint_resolved</strong> - When a customer complaint is resolved</li>
                                <li><strong>delivery_delay_confirmed</strong> - When a delivery delay is confirmed and communicated</li>
                                <li><strong>goodwill_approved</strong> - When goodwill compensation is approved</li>
                            </ul>
                            <p>Coupons should be generated in Shopify via Klaviyo flows.</p>
                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
